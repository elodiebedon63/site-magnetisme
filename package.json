{
  "name": "elodie-bedon-magnetisme",
  "version": "1.0.0",
  "description": "site vitrine",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "npm run prebuild && astro dev",
    "dev": "astro dev",
    "prebuild": "node scripts/copy-cname.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,css,astro,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,astro,json}\"",
    "debug:jsonld": "node scripts/generate-jsonld.mjs",
    "debug:qrcode": "node scripts/generate-qrcode.mjs",
    "ci": "npm ci && npm run lint && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/qrcode": "^1.5.6",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "qrcode": "^1.5.4"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/jost": "^5.2.8",
    "astro": "^5.18.2",
    "sharp": "^0.34.5"
  }
}
