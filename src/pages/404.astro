---
// Page servie par GitHub Pages pour toute URL inexistante.
// Elle redirige automatiquement vers la page d'accueil.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <!-- Redirection sans JavaScript (fallback) -->
    <meta http-equiv="refresh" content={`0; url=${base}`} />
    <link rel="canonical" href={base} />
    <title>Redirection vers l'accueil…</title>
    <!-- Redirection immédiate sans ajout dans l'historique du navigateur -->
    <script is:inline define:vars={{ base }}>
      window.location.replace(base);
    </script>
  </head>
  <body>
    <p>Page introuvable — redirection vers <a href={base}>l'accueil</a>…</p>
  </body>
</html>
