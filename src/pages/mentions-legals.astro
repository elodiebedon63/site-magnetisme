---
import BaseLayout from '../layouts/BaseLayout.astro';
import TextSection from '../components/sections/TextSection.astro';
import business from '../data/business.json';
import { emailHref, phoneHref, phoneDisplay } from '../lib/business.ts';
import { lastModified } from '../lib/date.ts';

const lastUpdated = lastModified(import.meta.url);
---

<BaseLayout
  title={`Mentions légales — ${business.name}, ${business.short}`}
  ogTitle={`Mentions légales — ${business.name}`}
  description={`Mentions légales du site d'${business.name}, ${business.description}`}
>
  <TextSection title="Mentions légales">
    <p>
      Dernière mise à jour : {lastUpdated}.
    </p>

    <h2>Éditeur du site</h2>
    <p>Ce site est édité par :</p>
    <p>
      {business.name}<br />
      Entrepreneur individuel<br />
      SIRET : 831 670 369 00030<br />
      Code APE : 96.09Z - Autres services personnels n.c.a<br />
      Adresse : {business.address.street}
      {business.address.postalCode}
      {business.address.locality}<br />
      Email : <a href={emailHref()}>{business.email}</a><br />
      Téléphone : <a href={phoneHref()}>{phoneDisplay()}</a>
    </p>

    <h2>Hébergement</h2>
    <p>
      Ce site est hébergé par :<br />
      GitHub, Inc.<br />
      88 Colin P. Kelly Jr. Street San Francisco, CA 94107 États-Unis<br />
      Téléphone : +1 (877) 448-4820<br />
      Site web : https://github.com
    </p>

    <h2>Activité</h2>
    <p>
      {business.name} exerce en tant qu' Entrepreneur individuel dans le domaine de praticienne en magnétisme
      et massages énergétiques, non assujetti à la TVA en vertu de l'article 293 B du CGI.
    </p>

    <h2>Contenu tiers</h2>
    <p>Ce site intègre des services tiers :</p>
    <p>
      YouTube (Google LLC) : les liens vidéo présents sur ce site ouvrent YouTube dans un nouvel
      onglet. Aucune vidéo n'est intégrée directement. L'utilisation de YouTube est soumise aux
      conditions d'utilisation et à la politique de confidentialité de Google.
    </p>
    <p>
      Google Calendar (Google LLC) : le bouton de réservation ouvre Google Calendar sous forme de
      popup intégrée sur ordinateur, et dans un nouvel onglet sur mobile. Son utilisation est soumise
      à la politique de confidentialité de Google.
    </p>
    <p>
      Google Tag Manager &amp; Google Analytics (Google LLC) : sous réserve de votre consentement,
      ce site recourt à Google Tag Manager et Google Analytics pour mesurer son audience et la
      performance technique des pages (Core Web Vitals). Leur utilisation est soumise à la politique
      de confidentialité de Google.
    </p>
    <p>
      Ces services peuvent collecter des données (cookies, adresse IP) indépendamment de ce site.
      Vous pouvez consulter les politiques de Google pour en savoir plus.
    </p>

    <h2>Propriété intellectuelle</h2>
    <p>
      L'ensemble du contenu de ce site (textes, visuels, structure) est la propriété de
      {business.name}, sauf contenus tiers expressément mentionnés. Toute reproduction sans
      autorisation est interdite.
    </p>

    <h2>Données personnelles & Cookies</h2>
    <p>
      Le traitement des données personnelles et des cookies (services tiers, exercice de vos droits)
      est détaillé dans notre
      <a href={`${import.meta.env.BASE_URL}confidentialite`}>politique de confidentialité</a>.
    </p>

    <h2>Responsabilité</h2>
    <p>
      {business.name} s'efforce de maintenir les informations de ce site à jour mais ne saurait être tenu
      responsable d'erreurs, d'omissions ou des contenus des sites tiers vers lesquels ce site renvoie.
    </p>
  </TextSection>
</BaseLayout>
