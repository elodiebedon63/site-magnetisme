---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import CarrouselSlide from '../shared/CarrouselSlide.astro';
import content from '../../data/content.json';

// Une slide du carrousel « À propos ». `img` est optionnel : sans image, un
// placeholder est affiché (ex. état élargi de conscience, photo à venir).
type SlideData = {
  img?: string;
  alt: string;
  tag: string;
  title: string;
  precontent?: string[];
  list?: string[];
  content: string[];
  alert?: string;
};

const aproposSlides = content.apropos.slides as SlideData[];

// Images du carrousel — Astro génère automatiquement des WebP optimisés et
// dimensionnés. Chargées par nom de fichier (depuis content.json) via glob.
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/images/*.{jpg,jpeg,png}',
  { eager: true },
);
const slides = aproposSlides.map((slide) => ({
  ...slide,
  image: slide.img ? imageModules[`../../assets/images/${slide.img}`].default : null,
}));
const total = slides.length;
---

<section id="apropos">
  <!-- GAUCHE : carrousel images -->
  <div
    class="carousel-wrap reveal"
    role="region"
    aria-roledescription="carrousel"
    aria-label="Découverte du cabinet et des soins"
  >
    <div class="carousel-track" aria-live="polite">
      {
        slides.map((slide, i) => (
          <div
            class:list={['carousel-slide', { active: i === 0 }]}
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} sur ${total}`}
            aria-hidden={i === 0 ? 'false' : 'true'}
          >
            {slide.image ? (
              <Image src={slide.image} alt={slide.alt} width={900} loading="lazy" />
            ) : (
              <div class="slide-placeholder">
                <span>Photo à venir</span>
              </div>
            )}
          </div>
        ))
      }

      <div class="carousel-counter" aria-hidden="true"><span id="slideNum">1</span> / {total}</div>
    </div>

    <!-- Flèches -->
    <button
      class="carousel-btn carousel-prev"
      id="prevBtn"
      type="button"
      aria-label="Slide précédente"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M10 3L5 8l5 5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    </button>
    <button
      class="carousel-btn carousel-next"
      id="nextBtn"
      type="button"
      aria-label="Slide suivante"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M6 3l5 5-5 5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
    </button>

    <!-- Dots -->
    <div class="carousel-dots" role="tablist" aria-label="Choisir une slide">
      {
        slides.map((_, i) => (
          <button
            class:list={['carousel-dot', { active: i === 0 }]}
            type="button"
            data-index={i}
            aria-label={`Aller à la slide ${i + 1}`}
            aria-current={i === 0 ? 'true' : undefined}
          />
        ))
      }
    </div>
  </div>

  <!-- DROITE : textes liés aux slides (une CarrouselSlide par slide) -->
  <div class="apropos-text reveal reveal-delay-1">
    {
      slides.map((slide, i) => (
        <CarrouselSlide
          tag={slide.tag}
          title={slide.title}
          precontent={slide.precontent}
          list={slide.list}
          content={slide.content}
          alert={slide.alert}
          active={i === 0}
        />
      ))
    }
  </div>
</section>

<style>
  /* Section « À propos » + carrousel */
  #apropos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    background: var(--white);
  }

  /* Carrousel (gauche) */
  .carousel-wrap {
    position: relative;
  }
  .carousel-track {
    position: relative;
    margin: 0 auto;
    width: 65%;
    aspect-ratio: 3/4;
    border-radius: 3px;
    overflow: hidden;
    background: var(--beige-dark);
  }
  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .carousel-slide.active {
    opacity: 1;
  }
  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Placeholder affiché pour une slide sans image (photo à venir). */
  .slide-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--beige-dark);
  }
  .slide-placeholder span {
    opacity: 0.45;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
  }

  /* Flèches */
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: 40px;
    height: 40px;
    background: rgba(253, 250, 245, 0.88);
    border: 1px solid rgba(90, 60, 40, 0.1);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.25s,
      transform 0.25s;
    backdrop-filter: blur(4px);
  }
  .carousel-btn:hover {
    background: var(--white);
    transform: translateY(-50%) scale(1.08);
  }
  .carousel-btn svg {
    stroke: var(--text);
  }
  .carousel-prev {
    left: -18px;
  }
  .carousel-next {
    right: -18px;
  }

  /* Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 1.2rem;
  }
  .carousel-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--beige-dark);
    border: 1px solid var(--sage);
    cursor: pointer;
    transition:
      background 0.3s,
      transform 0.3s;
    padding: 0;
  }
  .carousel-dot.active {
    background: var(--sage);
    transform: scale(1.2);
  }

  /* Compteur */
  .carousel-counter {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.8);
    background: rgba(58, 46, 40, 0.35);
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    backdrop-filter: blur(4px);
  }

  /* Conteneur des slides de texte (droite). Contexte de positionnement pour les
     .slide-text empilées (stylées dans CarrouselSlide.astro). */
  .apropos-text {
    position: relative;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    #apropos {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>

<script>
  // Carrousel « À propos » : synchronise images, textes, pastilles et compteur.
  const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
  const texts = document.querySelectorAll<HTMLElement>('.slide-text');
  const dots = document.querySelectorAll<HTMLElement>('.carousel-dot');
  const slideNum = document.getElementById('slideNum');

  if (slides.length > 0) {
    let current = 0;

    const goTo = (index: number) => {
      slides[current].classList.remove('active');
      slides[current].setAttribute('aria-hidden', 'true');
      texts[current].classList.remove('active');
      dots[current].classList.remove('active');
      dots[current].removeAttribute('aria-current');

      current = (index + slides.length) % slides.length;

      slides[current].classList.add('active');
      slides[current].setAttribute('aria-hidden', 'false');
      texts[current].classList.add('active');
      dots[current].classList.add('active');
      dots[current].setAttribute('aria-current', 'true');
      if (slideNum) slideNum.textContent = String(current + 1);
    };

    document.getElementById('prevBtn')?.addEventListener('click', () => goTo(current - 1));
    document.getElementById('nextBtn')?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot) => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));
  }
</script>
