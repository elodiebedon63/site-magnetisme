---
import content from '../../data/content.json';

const quote = content.quote;
---

<div class="quote-container">
  <div class="quote-bg" id="quoteBg"></div>
  <div class="quote">
    <blockquote>
      {quote.quote}
    </blockquote>
    <cite>{quote.cite}</cite>
  </div>
</div>

<style>
  /* Bandeau citation avec parallaxe */
  .quote-container {
    height: 460px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .quote-bg {
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(ellipse at 25% 60%, rgba(29, 136, 173, 0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 30%, rgba(11, 98, 129, 0.22) 0%, transparent 50%),
      linear-gradient(135deg, #c8dde5 0%, #b8ced8 100%);
    will-change: transform;
  }
  .quote {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 2rem;
  }
  .quote blockquote {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2vw, 1.6rem);
    font-weight: 300;
    font-style: italic;
    color: var(--text);
    line-height: 1.45;
    max-width: 80%;
    margin: 0 auto;
    text-align: center;
  }
  .quote cite {
    display: block;
    margin-top: 1rem;
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-light);
    font-style: normal;
  }
</style>

<script>
  // Parallaxe du fond du bandeau au défilement. Throttle via requestAnimationFrame,
  // listener passif. Désactivé si l'utilisateur préfère réduire les animations.
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const quoteBg = prefersReducedMotion ? null : document.getElementById('quoteBg');

  if (quoteBg) {
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const rect = quoteBg.parentElement!.getBoundingClientRect();
          const offset = (window.innerHeight / 2 - rect.top - rect.height / 2) * 0.18;
          quoteBg.style.transform = `translateY(${offset}px)`;
          ticking = false;
        });
      },
      { passive: true },
    );
  }
</script>
