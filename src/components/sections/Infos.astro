---
import Social from '../shared/Social.astro';
---

<section id="infos">
  <div>
    <p class="section-tag reveal">Me contacter</p>
    <h2 class="reveal">Infos <em>pratiques</em></h2>
  </div>
  <div>
    <div class="infos-block reveal reveal-delay-1">
      <h3>Sur rendez-vous au cabinet</h3>
      <div class="info-item">
        <div class="info-icon">📍</div>
        <div>
          <strong>Cabinet Psy'Jaude</strong>
          2 avenue Julien, place Jaude<br />
          63000 Clermont-Ferrand<br />
          <em style="font-size: 0.8rem; color: var(--sage-dark)">
            Tram / Bus A-B-C-E4 — Arrêt Jaude<br />Parkings payants Jaude 1 et Jaude 2
          </em>
        </div>
      </div>
      <div class="info-item">
        <div class="info-icon">🕐</div>
        <div>
          <strong>Horaires</strong>
          <div class="horaires-grid">
            <span>Lundi</span>
            <span>9h–12h et 13h30–18h</span>
            <span>Mardi</span>
            <span>9h–12h et 13h30–18h</span>
            <span>Mercredi</span>
            <span>9h–12h et 13h30–18h</span>
            <span>Jeudi</span>
            <span>9h–12h et 13h30–18h</span>
            <span>Vendredi</span>
            <span>9h–12h et 13h30–18h</span>
            <span>Samedi</span>
            <span>9h–12h</span>
            <span>Dimanche / Jours Fériés</span>
            <span>Fermé</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div>
    <div class="infos-block reveal">
      <h3>Comment prendre rendez-vous</h3>
      <div class="info-item">
        <div class="info-icon">✉️</div>
        <div>
          <strong>Par mail</strong>
          <a href="mailto:elodie.bedon@hotmail.fr">elodie.bedon@hotmail.fr</a>
          <br />
          <em style="font-size: 0.8rem; color: var(--text-light)">
            Premier contact recommandé ou pour toute question
          </em>
        </div>
      </div>
      <div class="info-item">
        <div class="info-icon">📞</div>
        <div>
          <strong>Par téléphone</strong>
          <a href="tel:0768485414">07 68 48 54 14</a>
          <br />
          <em style="font-size: 0.8rem; color: var(--text-light)">
            Laissez un message, je vous rappelle
          </em>
        </div>
      </div>
      <div class="info-item">
        <div class="info-icon">📋</div>
        <div>
          <strong>Via le formulaire</strong>
          Utilisez le formulaire ci-dessous en précisant le type de soin souhaité et vos disponibilités.
        </div>
      </div>
    </div>

    <div class="infos-block reveal reveal-delay-2">
      <h3>Mes réseaux sociaux</h3>
      <Social />
    </div>
  </div>
</section>

<style>
  /* Section « Infos pratiques » (les réseaux sociaux sont dans Social.astro). */
  #infos {
    background: var(--white);
    display: flex;
    gap: 4rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  #infos > div {
    flex: 1 1 320px;
  }

  .infos-block h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 1.5rem;
  }
  .info-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.2rem;
    align-items: flex-start;
  }
  .info-icon {
    width: 38px;
    height: 38px;
    background: var(--beige);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.95rem;
  }
  .info-item div {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-light);
  }
  .info-item strong {
    display: block;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .horaires-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.3rem 1.5rem;
    margin-top: 0.4rem;
    font-size: 0.87rem;
    color: var(--text-light);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    #infos {
      gap: 3rem;
    }
  }
</style>
