---
import Social from '../shared/Social.astro';
import InfoItem from '../shared/InfoItem.astro';
import content from '../../data/content.json';
import business from '../../data/business.json';
import {
  addressLabel,
  addressLines,
  hoursDisplay,
  emailHref,
  phoneHref,
  phoneDisplay,
} from '../../lib/business';

type ResolvedItem = {
  icon: string;
  label?: string;
  text?: string;
  note?: string;
  link?: { href: string; text: string };
  hours?: { day: string; time: string }[];
};

// Un item peut référencer une donnée de business.json via `source` ; on y
// injecte alors la valeur dérivée (libellé/texte/lien/horaires) au build.
function resolve(item: { icon: string; [key: string]: any }): ResolvedItem {
  switch (item.source) {
    case 'address':
      return { ...item, label: addressLabel(), text: addressLines() };
    case 'hours':
      return { ...item, hours: hoursDisplay() };
    case 'email':
      return { ...item, link: { href: emailHref(), text: business.email } };
    case 'phone':
      return { ...item, link: { href: phoneHref(), text: phoneDisplay() } };
    default:
      return item;
  }
}

const infos = content.infos;

// Deux colonnes : le 1er bloc seul, puis le 2e bloc + les réseaux sociaux.
const [cabinet, rendezVous] = infos.blocks;
---

<section id="infos" aria-label="Informations pratiques et contact">
  <div>
    <p class="section-tag reveal">{infos.tag}</p>
    <h2 class="reveal" set:html={infos.title} />
  </div>

  <div>
    <div class="infos-block reveal reveal-delay-1">
      <h3>{cabinet.title}</h3>
      {cabinet.items.map((item) => <InfoItem {...resolve(item)} />)}
    </div>
  </div>

  <div>
    <div class="infos-block reveal">
      <h3>{rendezVous.title}</h3>
      {rendezVous.items.map((item) => <InfoItem {...resolve(item)} />)}
    </div>

    <div class="infos-block reveal reveal-delay-2">
      <h3>Mes réseaux sociaux</h3>
      <Social />
    </div>
  </div>
</section>

<style>
  /* Section « Infos pratiques » (les réseaux sociaux sont dans Social.astro). */
  #infos {
    background: var(--white);
    display: flex;
    gap: 4rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  #infos > div {
    flex: 1 1 320px;
  }

  .infos-block h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  /* Le style d'une ligne d'info (.info-item, icône, horaires…) est dans InfoItem.astro. */

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    #infos {
      gap: 3rem;
    }
  }
</style>
