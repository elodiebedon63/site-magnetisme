---
import { Image } from 'astro:assets';
import content from '../../data/content.json';
import logo from '../../assets/images/logo.svg';

const hero = content.hero;

const icons = import.meta.glob<string>('../../assets/svg/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const videoIconSvg = icons[`../../assets/svg/${hero.video.icon}`];
---

<section id="accueil" class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-circle-1"></div>
  <div class="hero-circle-2"></div>

  <div class="hero-circle-1"></div>
  <div class="hero-circle-2"></div>

  <Image class="hero-logo" src={logo} alt="logo" width={80} height={82} loading="eager" />

  <div class="hero-content">
    <p class="hero-tag">
      {hero.tag.map((t, i) => (
        <>
          {i > 0 && i % 2 !== 0 && <span class="tag-sep"> · </span>}
          {i > 0 && i % 2 === 0 && <span class="tag-sep-desktop"> · </span>}
          {i > 0 && i % 2 === 0 && <br class="tag-sep-mobile" />}
          {t}
        </>
      ))}
    </p>
    <h1>
      {hero.title.map((line) => <span class="title-line" set:html={line} />)}
    </h1>
    <p class="hero-presub" set:html={hero.subtitle} />
    <p class="hero-sub">
      {hero.main.map((line) => <span class="sub-line" set:html={line} />)}
    </p>

    <div class="hero-ctas">
      <a
        href={hero.video.src}
        class="hero-cta hero-cta-secondary"
        target="_blank"
        rel="noopener noreferrer"
      >
        {hero.video.title}
        <Fragment set:html={videoIconSvg} />
      </a>
    </div>
  </div>
</section>

<style>
  /* Section d'accueil (hero). Le bouton partagé .hero-cta est dans global.css. */
  #accueil {
    position: relative;
    height: 100vh;
    min-height: 620px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: -15%;
    background:
      radial-gradient(ellipse at 65% 35%, rgba(29, 136, 173, 0.2) 0%, transparent 55%),
      radial-gradient(ellipse at 15% 75%, rgba(11, 98, 129, 0.15) 0%, transparent 50%),
      linear-gradient(160deg, #e8f0f4 0%, #dce8ec 100%);
    will-change: transform;
  }
  .hero-circle-1 {
    position: absolute;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    border: 1px solid rgba(29, 136, 173, 0.18);
    top: 50%;
    right: 8%;
    transform: translateY(-50%);
  }
  .hero-circle-2 {
    position: absolute;
    width: 340px;
    height: 340px;
    border-radius: 50%;
    background: rgba(29, 136, 173, 0.07);
    top: 50%;
    right: 11%;
    transform: translateY(-50%);
  }
  .hero-logo {
    position: absolute;
    right: 15%;
    top: 50%;
    transform: translateY(-50%);
    width: 200px;
    height: auto;
    opacity: 0.5;
    /* Empêche la sélection et le glisser-déposer du logo. */
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 5rem 4rem 0;
    max-width: 860px;
  }
  .hero-tag {
    display: inline-block;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sage-dark);
    margin-bottom: 0;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }
  .tag-sep-mobile { display: none; }

  .hero-tag::before {
    content: '';
    display: inline-block;
    width: 30px;
    height: 1px;
    background: var(--sage);
    vertical-align: middle;
    margin-right: 10px;
  }
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.8rem, 5.5vw, 4rem);
    font-weight: 300;
    line-height: 1.08;
    color: var(--text);
    margin-bottom: 1.8rem;
    /* En PC, le titre s'étend à la largeur naturelle du texte (sans contrainte). */
    width: max-content;
    max-width: none;
    opacity: 0;
    animation: fadeUp 0.9s 0.4s forwards;
  }
  .title-line {
    display: block;
  }
  /* `em` provient de set:html (pas d'attribut de scope Astro) → :global() borné. */
  h1 :global(em) {
    color: var(--sage-dark);
    font-style: italic;
  }
  .hero-presub {
    font-size: 1rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--text-light);
    max-width: 700px;
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fadeUp 0.9s 0.5s forwards;
  }
  .hero-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-light);
    max-width: 750px;
    margin-bottom: 1.6rem;
    opacity: 0;
    animation: fadeUp 0.9s 0.55s forwards;
  }
  .sub-line {
    display: block;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
    animation: fadeUp 0.9s 0.85s forwards;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    .tag-sep-desktop { display: none; }
    .tag-sep-mobile  { display: inline; }
    .hero-tag {
      padding-left: 40px;
      text-indent: -40px;
    }
    h1 {
      /* En mobile, le titre se replie normalement dans la largeur disponible. */
      width: auto;
    }
    #accueil {
      height: auto;
      min-height: unset;
      padding: 8rem 0 3rem;
      align-items: flex-start;
    }
    .hero-content {
      padding: 0 2rem;
    }
    .hero-ctas {
      margin-top: 3rem;
    }
  }
</style>

<script>
  // Parallaxe du fond du hero au défilement. Throttle via requestAnimationFrame,
  // listener passif. Désactivé si l'utilisateur préfère réduire les animations.
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const heroBg = prefersReducedMotion ? null : document.getElementById('heroBg');

  if (heroBg) {
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          heroBg.style.transform = `translateY(${window.scrollY * 0.32}px)`;
          ticking = false;
        });
      },
      { passive: true },
    );
  }
</script>
