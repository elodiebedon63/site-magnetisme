---
import content from '../../data/content.json';
import PratiqueCard from '../shared/PratiqueCard.astro';

const services = content.seances;

/**
 * `compact` : cartes réduites au titre + prix + durée (idem /tarifs).
 * `showTag` : affiche le surtitre (« Mes accompagnements »). Masqué sur /tarifs.
 */
interface Props {
  compact?: boolean;
  showTag?: boolean;
}
const { compact = false, showTag = true } = Astro.props;

const seancesList = services.services;
---

<section id="seances" aria-label="Séances et tarifs">
  <div class="seances-intro">
    {showTag && <p class="section-tag reveal">{services.tag}</p>}
    <h2 class="reveal" set:html={services.title} />
    <p class="reveal reveal-delay-1" set:html={services.description.join('<br>')} />
  </div>

  <div class="pratiques-grid">
    {services.forfait.map((f) => (
      <div class="pratique-card forfait-card reveal">
        <div class="pratique-title">{f.title}</div>
        {f.description.map((line: string) => <p class="pratique-desc" set:html={line} />)}
        <div class="pratique-price">
          <strong>{f.price}</strong>
          <span>{f.duration}</span>
        </div>
      </div>
    ))}
    <p class="soins-label reveal">{services.soins}</p>
    {seancesList.map((seances, i) => <PratiqueCard {...seances} index={i} compact={compact} />)}
  </div>
</section>

<style>
  /* Section « Séances & tarifs » (grille + outils).
     Le style d'une carte est dans PratiqueCard.astro. */
  #seances {
    background: var(--beige);
    position: relative;
    overflow: hidden;
  }
  #seances::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 450px;
    height: 450px;
    border-radius: 50%;
    background: radial-gradient(ellipse, rgba(29, 136, 173, 0.1), transparent 70%);
    pointer-events: none;
  }
  .seances-intro {
    max-width: 1000px;
    margin-bottom: 4rem;
  }
  .seances-intro p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-light);
    margin-top: 1rem;
  }

  .pratiques-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .soins-label {
    grid-column: 1 / -1;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--text);
    margin-top: 1rem;
  }

  /* Carte forfait — reprend le style de PratiqueCard, s'étend sur 2 colonnes */
  .forfait-card {
    grid-column: 1 / -1;
    background: var(--white);
    padding: 2.2rem 2.5rem;
    border-radius: 3px;
    position: relative;
    transition: transform 0.3s, box-shadow 0.3s;
    overflow: hidden;
  }
  .forfait-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 0;
    background: var(--sage);
    transition: height 0.4s;
  }
  .forfait-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 45px rgba(11, 98, 129, 0.12);
  }
  .forfait-card:hover::before {
    height: 100%;
  }
  .forfait-card .pratique-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
  }
  .forfait-card .pratique-desc {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text-light);
    margin-bottom: 0.6rem;
  }
  .forfait-card .pratique-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    border-top: 1px solid var(--beige-dark);
    padding-top: 1.2rem;
    margin-top: 0.6rem;
  }
  .forfait-card .pratique-price strong {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--terre);
  }
  .forfait-card .pratique-price span {
    font-size: 0.8rem;
    color: var(--text-light);
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    .pratiques-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
