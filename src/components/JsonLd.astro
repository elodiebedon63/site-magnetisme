---
/**
 * Rend une ou plusieurs données structurées Schema.org (JSON-LD).
 * Accepte un objet unique ou un tableau d'objets — un <script> par schéma.
 *
 * Exemple :
 *   <JsonLd schema={{ '@context': 'https://schema.org', '@type': 'Article', ... }} />
 */
type Schema = Record<string, unknown>;

interface Props {
  schema: Schema | Schema[];
}

const { schema } = Astro.props;
const items = Array.isArray(schema) ? schema : [schema];
---

{items.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
