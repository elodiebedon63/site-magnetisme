---
/**
 * Panneau de texte d'une slide du carrousel « À propos ».
 * Affiche : surtitre (.section-tag), titre (h2), paragraphes d'intro optionnels
 * (precontent), liste optionnelle, paragraphes (content), un encart d'alerte
 * optionnel (alert) introduit par une icône d'avertissement, puis un lien
 * optionnel (link, ouvert dans un nouvel onglet). Le contenu peut contenir du
 * HTML (<em>, <br>), d'où set:html — les données proviennent du projet
 * (content.json), de confiance.
 *
 * La visibilité (classe `.active`) est pilotée par le script du carrousel dans
 * Apropos.astro ; `active` initialise la première slide.
 */
interface Props {
  tag: string;
  precontent?: string[];
  list?: string[];
  content: string[];
  alert?: string;
  link?: { href: string; label: string };
  active?: boolean;
}

const { tag, precontent, list, content, alert, link, active = false } = Astro.props;

// Icône d'avertissement (rendue inline pour hériter de `currentColor`), affichée
// en tête de l'encart d'alerte.
const icons = import.meta.glob<string>('../../assets/svg/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const alertIcon = icons['../../assets/svg/alert.svg'];
---

<div class:list={['slide-text', { active }]}>
  <p class="section-tag" set:html={tag} />
  {precontent?.map((paragraph) => <p set:html={paragraph} />)}
  {
    list && (
      <ul class="slide-list">
        {list.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    )
  }
  {content.map((paragraph) => <p set:html={paragraph} />)}
  {
    alert && (
      <p class="slide-alert">
        <Fragment set:html={alertIcon} />
        <span set:html={alert} />
      </p>
    )
  }
  {
    link && (
      <a class="slide-link" href={link.href} target="_blank" rel="noopener noreferrer">
        {link.label}
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M6 3h7v7M13 3L5 11"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>
    )
  }
</div>

<style>
  /* Slides empilées : seule la slide active prend de la place (position relative)
     et devient visible ; les autres sont superposées et masquées. */
  .slide-text {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
    transform: translateY(10px);
    pointer-events: none;
  }
  .slide-text.active {
    opacity: 1;
    transform: translateY(0);
    position: relative;
    pointer-events: auto;
  }

  .slide-text .section-tag {
    font-size: 1.5rem;
    margin-bottom: 0.8rem;
  }
  /* Pas de petite barre décorative devant le surtitre dans le carrousel. */
  .slide-text .section-tag::before {
    display: none;
  }
  /* `em` provient de set:html (pas d'attribut de scope Astro) → :global() borné. */
  .slide-text .section-tag :global(em) {
    color: var(--sage);
    font-style: normal;
  }
  .slide-text h2 {
    margin-bottom: 1.4rem;
  }
  .slide-text p {
    font-size: 0.98rem;
    line-height: 1.3;
    color: var(--text-light);
    margin-bottom: 1rem;
  }

  .slide-list {
    list-style: none;
    margin-bottom: 1rem;
  }
  .slide-list li {
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--text-light);
    padding-left: 1.2rem;
    position: relative;
    margin-bottom: 0.5rem;
  }
  .slide-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--sage);
  }

  /* Encart d'alerte optionnel, introduit par l'icône d'avertissement. */
  .slide-text .slide-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1.4rem;
    margin-bottom: 0;
    padding: 0.9rem 1.1rem;
    border-left: 3px solid var(--terre);
    background: var(--beige);
    border-radius: 2px;
    color: var(--text);
  }
  .slide-alert :global(.inline-alert) {
    flex-shrink: 0;
    width: 1.2em;
    height: 1.2em;
    margin-top: 0.15em;
    color: var(--terre);
  }

  /* Lien optionnel (ex. vidéo de présentation), ouvert dans un nouvel onglet. */
  .slide-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.4rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--sage);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 0.25s,
      border-color 0.25s;
  }
  .slide-link:hover {
    color: var(--terre);
    border-bottom-color: currentColor;
  }
  .slide-link svg {
    flex-shrink: 0;
    transition: transform 0.25s;
  }
  .slide-link:hover svg {
    transform: translate(2px, -2px);
  }
</style>
