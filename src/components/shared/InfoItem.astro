---
/**
 * Une ligne d'information de la section « Infos pratiques » : une icône et un
 * contenu (libellé en gras, puis selon les cas un lien, un texte, une grille
 * d'horaires et/ou une mention secondaire).
 *
 * `text` et `note` peuvent contenir du HTML (<br>) → set:html ; les données
 * proviennent du projet (infos.json), de confiance.
 */
type Hour = { day: string; time: string };
type Link = { href: string; text: string };

interface Props {
  icon: string;
  label?: string;
  text?: string;
  note?: string;
  link?: Link;
  hours?: Hour[];
}

const { icon, label, text, note, link, hours } = Astro.props;
---

<div class="info-item">
  <div class="info-icon">{icon}</div>
  <div>
    {label && <strong>{label}</strong>}
    {link && <a href={link.href}>{link.text}</a>}
    {text && <Fragment set:html={text} />}
    {
      hours && (
        <div class="horaires-grid">
          {hours.map((h) => (
            <Fragment>
              <span>{h.day}</span>
              <span>{h.time}</span>
            </Fragment>
          ))}
        </div>
      )
    }
    {note && <em class="info-note" set:html={note} />}
  </div>
</div>

<style>
  .info-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.2rem;
    align-items: flex-start;
  }
  .info-icon {
    width: 38px;
    height: 38px;
    background: var(--beige);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.95rem;
  }
  .info-item div {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-light);
  }
  .info-item strong {
    display: block;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }
  /* Mention secondaire (ancien <em> à style inline). */
  .info-note {
    display: block;
    font-size: 0.8rem;
    color: var(--text-light);
    margin-top: 0.15rem;
  }

  .horaires-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.3rem 1.5rem;
    margin-top: 0.4rem;
    font-size: 0.87rem;
    color: var(--text-light);
  }
</style>
