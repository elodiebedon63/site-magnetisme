---
/**
 * Une ligne d'information de la section « Infos pratiques » : une icône et un
 * contenu (libellé en gras, puis selon les cas un lien, un texte, une grille
 * d'horaires et/ou une mention secondaire).
 *
 * `text` et `note` peuvent contenir du HTML (<br>) → set:html ; les données
 * proviennent du projet (infos.json), de confiance.
 */
type Hour = { day: string; time: string };
type Link = { href: string; text: string };

interface Props {
  /** Nom de fichier SVG dans src/assets/svg (ex. « phone.svg »). */
  icon: string;
  label?: string;
  text?: string;
  note?: string;
  link?: Link;
  hours?: Hour[];
}

const { icon, label, text, note, link, hours } = Astro.props;

// Contenu brut des SVG d'icônes (rendus inline pour hériter de `currentColor`).
const icons = import.meta.glob<string>('../../assets/svg/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
const iconSvg = icons[`../../assets/svg/${icon}`];
---

<div class="info-item">
  <div class="info-icon" set:html={iconSvg} />
  <div>
    {label && <strong>{label}</strong>}
    {link && <a href={link.href}>{link.text}</a>}
    {text && <Fragment set:html={text} />}
    {
      hours && (
        <div class="horaires-grid">
          {hours.map((h) => (
            <Fragment>
              <span>{h.day}</span>
              <span>{h.time}</span>
            </Fragment>
          ))}
        </div>
      )
    }
    {note && <em class="info-note" set:html={note} />}
  </div>
</div>

<style>
  .info-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.2rem;
    align-items: flex-start;
  }
  .info-icon {
    width: 38px;
    height: 38px;
    background: var(--beige);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--sage-dark);
  }
  .info-icon :global(svg) {
    display: block;
  }
  .info-item div {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-light);
  }
  .info-item strong {
    display: block;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }
  .info-item a {
    color: var(--text);
    text-decoration: none;
    position: relative;
    transition: color 0.3s;
  }
  .info-item a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--sage);
    transition: width 0.3s ease, background 0.3s;
  }
  .info-item a:hover {
    color: var(--sage-dark);
  }
  .info-item a:hover::after {
    width: 100%;
    background: var(--sage-dark);
  }

  /* Mention secondaire (ancien <em> à style inline). */
  .info-note {
    display: block;
    font-size: 0.8rem;
    color: var(--text-light);
    margin-top: 0.15rem;
  }

  .horaires-grid {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.3rem 1.5rem;
    margin-top: 0.4rem;
    font-size: 0.87rem;
    color: var(--text-light);
  }
</style>
