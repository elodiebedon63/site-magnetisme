---
import CalendarButton from './CalendarButton.astro';
import '../styles/nav.css';

const base = import.meta.env.BASE_URL;
---

<nav id="navbar">
  <a href={`${base}#accueil`} class="nav-logo">
    <img src={`${base}logo-cercle.png`} alt="Logo Élodie Bedon" width="32" />
    <div class="nav-logo-text">
      Élodie Bedon
      <span>Magnétiseuse · Clermont-Ferrand</span>
    </div>
  </a>
  <ul class="nav-links">
    <li><a href={`${base}#apropos`}>À propos</a></li>
    <li><a href={`${base}#seances`}>Séances & tarifs</a></li>
    <li><a href={`${base}#infos`}>Infos pratiques</a></li>
    <li><CalendarButton id="calendarBtnNav" /></li>
  </ul>
  <button
    class="burger"
    id="burgerBtn"
    type="button"
    aria-label="Ouvrir le menu"
    aria-expanded="false"
    aria-controls="mobileMenu"
  >
    <span></span><span></span><span></span>
  </button>
</nav>
