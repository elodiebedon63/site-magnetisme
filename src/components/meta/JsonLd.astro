---
/**
 * Émet les données structurées Schema.org (JSON-LD) du site.
 *
 * Le schéma LocalBusiness est dérivé de la source unique src/data/business.json
 * (via src/lib/business.ts), enrichi de l'URL canonique de la page et de l'image
 * Open Graph. Des schémas additionnels propres à la page peuvent être fournis
 * via la prop `schema`.
 */
import { localBusinessSchema } from '../../lib/business';

type Schema = Record<string, unknown>;

interface Props {
  /** URL absolue de l'image Open Graph (calculée par le layout). */
  image: string;
  /** Schémas additionnels propres à la page (Article, Service, BreadcrumbList…). */
  schema?: Schema | Schema[];
}

const { image, schema } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const items: Schema[] = [localBusinessSchema(canonical, image), ...pageSchemas];
---

{items.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
