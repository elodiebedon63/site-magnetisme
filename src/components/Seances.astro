---
import services from '../data/services.json';
import PratiqueCard from './PratiqueCard.astro';
import '../styles/seances.css';

const outils = [
  'Apposition des mains',
  'Souffle et prières',
  'Cristaux & pierres',
  'Pendule',
  'Bol tibétain',
  'Massage énergétique',
  'Visualisation',
  'Rêve éveillé',
  'Lecture de Tarot',
];
---

<section id="seances">
  <div class="seances-intro">
    <p class="section-tag reveal">Mes accompagnements</p>
    <h2 class="reveal">Séances <em>&</em> tarifs</h2>
    <p class="reveal reveal-delay-1">
      Chaque soin est une expérience unique, adaptée à votre situation du moment. La première séance
      permet de nous découvrir et de définir ensemble le cadre le plus adapté.
    </p>
  </div>

  <div class="pratiques-grid">
    {services.map((service, i) => <PratiqueCard {...service} index={i} />)}
  </div>

  <!-- Outils -->
  <div class="outils-section reveal">
    <h3>Outils utilisés lors des soins</h3>
    <div class="outils-grid">
      {outils.map((outil) => <div class="outil-pill">{outil}</div>)}
    </div>
  </div>
</section>
