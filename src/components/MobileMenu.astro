---
import CalendarButton from './CalendarButton.astro';
import '../styles/mobile-menu.css';

const base = import.meta.env.BASE_URL;
---

<div
  class="mobile-menu"
  id="mobileMenu"
  role="dialog"
  aria-modal="true"
  aria-label="Menu de navigation"
>
  <button class="mobile-close" id="closeMenu" aria-label="Fermer le menu">✕</button>
  <a href={`${base}#apropos`}>À propos</a>
  <a href={`${base}#seances`}>Séances & tarifs</a>
  <a href={`${base}#infos`}>Infos pratiques</a>
  <CalendarButton id="calendarBtnMobile" />
</div>
