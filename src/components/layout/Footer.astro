---
import business from '../../data/business.json';
import content from '../../data/content.json';

// L'année est figée au moment du build (régénérée à chaque déploiement).
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer>
  <p>
    © {year}
    <span>{business.name}</span> — {content.nav.tagline}
  </p>
  <p class="footer-legal">
    <a href={`${base}mentions-legals`}>Mentions légales</a>
    <a href={`${base}confidentialite`}>Politique de confidentialité</a>
    <button type="button" data-cookie-settings>Gérer les cookies</button>
  </p>
</footer>

<style>
  /* Pied de page */
  footer {
    background: var(--brown);
    color: rgba(255, 255, 255, 0.55);
    text-align: center;
    padding: 1.5rem 4rem;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
  }
  footer span {
    color: var(--sage-light);
  }
  .footer-legal {
    margin-top: 0.6rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.5rem;
  }
  .footer-legal a,
  .footer-legal button {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    transition: color 0.2s ease;
  }
  /* Le déclencheur « Gérer les cookies » est un <button> (action JS, pas un lien)
     remis au même rendu visuel que les liens voisins. */
  .footer-legal button {
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    padding: 0;
    font: inherit;
    letter-spacing: inherit;
    cursor: pointer;
  }
  .footer-legal a:hover,
  .footer-legal button:hover {
    color: var(--sage-light);
  }
</style>
