---
import { Image } from 'astro:assets';
import CalendarButton from '../shared/CalendarButton.astro';
import logoCercle from '../../assets/images/logo-cercle.png';
import business from '../../data/business.json';
import content from '../../data/content.json';

const base = import.meta.env.BASE_URL;
const { nav } = content;

/**
 * `minimal` : barre réduite au logo seul (sans liens de navigation, bouton de
 * réservation ni burger). Utilisée par les pages autonomes (ex. /tarifs).
 */
interface Props {
  minimal?: boolean;
}
const { minimal = false } = Astro.props;
---

<nav id="navbar">
  <a href={`${base}#accueil`} class="nav-logo">
    <Image src={logoCercle} alt="logo" width={32} height={32} densities={[2]} loading="eager" />
    <div class="nav-logo-text">
      {business.name}
      <span>{nav.tagline}</span>
    </div>
  </a>
  {
    !minimal && (
      <>
        <ul class="nav-links">
          {nav.links.map((link) => (
            <li>
              <a href={`${base}${link.href}`}>{link.label}</a>
            </li>
          ))}
          <li>
            <CalendarButton id="calendarBtnNav" />
          </li>
        </ul>
        <button
          class="burger"
          id="burgerBtn"
          type="button"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
          aria-controls="mobileMenu"
        >
          <span class="burger-icon">
            <!-- Icône ouverture : deux traits inégaux -->
            <svg class="icon-open" width="24" height="20" viewBox="0 0 24 20" fill="none" stroke="currentColor" stroke-linecap="round">
              <line x1="0" y1="5" x2="24" y2="5" stroke-width="1.2"/>
              <line x1="4" y1="15" x2="24" y2="15" stroke-width="1.2"/>
            </svg>
            <!-- Icône fermeture : × asymétrique -->
            <svg class="icon-close" width="24" height="20" viewBox="0 0 24 20" fill="none" stroke="currentColor" stroke-linecap="round">
              <line x1="3" y1="2" x2="21" y2="18" stroke-width="1.2"/>
              <line x1="7" y1="18" x2="21" y2="4" stroke-width="1.2"/>
            </svg>
          </span>
        </button>
      </>
    )
  }
</nav>

<style>
  /* Barre de navigation fixe + bouton burger */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 4rem;
    transition:
      background 0.4s,
      padding 0.4s,
      box-shadow 0.4s;
  }
  nav.scrolled {
    background: rgba(240, 245, 247, 0.95);
    backdrop-filter: blur(10px);
    padding: 1rem 4rem;
    box-shadow: 0 1px 20px rgba(11, 98, 129, 0.08);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;

    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .nav-logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    font-size: 1.2rem;
  }

  .nav-logo span {
    color: var(--sage-dark);
    font-style: italic;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-light);
    text-decoration: none;
    position: relative;
    transition: color 0.3s;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--sage);
    transition: width 0.3s;
  }
  .nav-links a:hover {
    color: var(--sage-dark);
  }
  .nav-links a:hover::after {
    width: 100%;
  }

  /* Bouton Google Agenda injecté dans la nav (style discret, type lien).
     :global car le <button> est ajouté au runtime par le script Google et
     n'aurait donc pas l'attribut de scope d'Astro. */
  :global(#calendarBtnNav button) {
    background: transparent;
    border: none;

    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;

    color: var(--text-light);
    cursor: pointer;

    padding: 0;
  }
  :global(#calendarBtnNav button:hover) {
    color: var(--sage-dark);
  }

  .burger {
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 4px;
    background: transparent;
    border: none;
    color: var(--text);
  }
  .burger-icon {
    position: relative;
    width: 24px;
    height: 20px;
    display: block;
  }
  .icon-open,
  .icon-close {
    position: absolute;
    top: 0;
    left: 0;
    transition: opacity 0.28s ease, transform 0.28s ease;
  }
  .icon-open  { opacity: 1; transform: rotate(0deg)   scale(1);   }
  .icon-close { opacity: 0; transform: rotate(-30deg) scale(0.7); }

  .burger.open .icon-open  { opacity: 0; transform: rotate(30deg)  scale(0.7); }
  .burger.open .icon-close { opacity: 1; transform: rotate(0deg)   scale(1);   }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    nav,
    nav.scrolled {
      padding: 1.2rem 2rem;
    }
    .nav-links {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
</style>

<script>
  // Ombre/fond de la barre de navigation au défilement. Throttle via
  // requestAnimationFrame, listener passif.
  const navbar = document.getElementById('navbar');

  if (navbar) {
    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          navbar.classList.toggle('scrolled', window.scrollY > 60);
          ticking = false;
        });
      },
      { passive: true },
    );
  }
</script>
