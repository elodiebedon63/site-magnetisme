---
import content from '../../data/content.json';
const base = import.meta.env.BASE_URL;
const { nav } = content;
const count = nav.links.length;
---

<div
  class="pill-menu"
  id="mobileMenu"
  role="dialog"
  aria-modal="true"
  aria-label="Menu de navigation"
  hidden
>
  {nav.links.map((link, i) => (
    <a
      href={`${base}${link.href}`}
      class="pill-item"
      style={`--open-delay: ${i * 70}ms; --close-delay: ${(count - 1 - i) * 70}ms`}
    >
      {link.label}
    </a>
  ))}
</div>

<style>
  .pill-menu {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 300;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    background: #fff;
    border-radius: 0 0 0 12px;
    padding: 0.6rem 1.2rem;
    box-shadow: -4px 4px 20px rgba(11, 98, 129, 0.1);
  }

  .pill-menu[hidden] {
    display: none;
  }

  .pill-item {
    display: block;
    width: 160px;
    padding: 0.5rem 0;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sage-dark);
    text-decoration: none;
    text-align: right;
    font-weight: 400;
    border-bottom: 1px solid var(--sage-dark);
    background: transparent;
    opacity: 0;
    animation: pillIn 0.22s ease forwards var(--open-delay, 0ms);
    transition: color 0.2s;
  }

  .pill-item:active {
    color: var(--brown);
  }

  @keyframes pillIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

</style>

<script>
  const burgerBtn = document.getElementById('burgerBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  if (burgerBtn && mobileMenu) {
    const navbar = document.getElementById('navbar');
    const open = () => {
      if (navbar) mobileMenu.style.top = navbar.offsetHeight + 'px';
      mobileMenu.hidden = false;
      burgerBtn.setAttribute('aria-expanded', 'true');
      burgerBtn.classList.add('open');
    };

    const close = () => {
      mobileMenu.hidden = true;
      burgerBtn.setAttribute('aria-expanded', 'false');
      burgerBtn.classList.remove('open');
    };

    burgerBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      mobileMenu.hidden ? open() : close();
    });

    mobileMenu.querySelectorAll('a').forEach((el) => {
      el.addEventListener('click', close);
    });

    document.addEventListener('click', (e) => {
      if (!mobileMenu.hidden && !mobileMenu.contains(e.target as Node)) {
        close();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.hidden) close();
    });

    window.addEventListener('scroll', () => {
      if (!mobileMenu.hidden) close();
    }, { passive: true });
  }
</script>
