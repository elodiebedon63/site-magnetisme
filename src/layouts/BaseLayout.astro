---
import Nav from '../components/layout/Nav.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Footer from '../components/layout/Footer.astro';
import CookieBanner from '../components/layout/CookieBanner.astro';
import JsonLd from '../components/meta/JsonLd.astro';
import FloatingCalendarButton from '../components/shared/FloatingCalendarButton.astro';
import business from '../data/business.json';
import '../styles/global.css';

type Schema = Record<string, unknown>;

/**
 * Layout commun à toutes les pages : balises <head> (SEO, Open Graph, JSON-LD,
 * polices, Google Calendar), barre de navigation, menu mobile et pied de page.
 * Chaque page n'a plus qu'à fournir son contenu principal via <slot />.
 */
export interface Props {
  title?: string;
  description?: string;
  /**
   * Titre court pour le partage social (Open Graph / Twitter). Distinct du
   * <title> (qui est long et riche en mots-clés pour le SEO). Surchargeable
   * par page.
   */
  ogTitle?: string;
  /** Image Open Graph (chemin absolu sous le domaine de prod). */
  ogImage?: string;
  /**
   * Données structurées Schema.org additionnelles, propres à la page
   * (ex. Article, Service, BreadcrumbList). Le LocalBusiness du site est
   * toujours émis automatiquement en plus.
   */
  jsonLd?: Schema | Schema[];
  /**
   * Barre de navigation réduite au logo (sans liens ni menu mobile). Pour les
   * pages autonomes accessibles uniquement par leur URL (ex. /tarifs).
   */
  minimalNav?: boolean;
  /**
   * Empêche l'indexation par les moteurs (balise robots noindex). À combiner
   * avec une exclusion du sitemap (astro.config.mjs) pour une page « cachée ».
   */
  noindex?: boolean;
  /** Masque le pied de page (ex. fiche tarifaire imprimable /tarifs). */
  noFooter?: boolean;
}

const {
  title = `${business.name} — ${business.short}`,
  description = business.description,
  ogTitle = `${business.name} — Magnétiseuse · Clermont-Ferrand`,
  ogImage = 'og-image.jpg',
  jsonLd,
  minimalNav = false,
  noindex = false,
  noFooter = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(`${base}${ogImage}`, Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>

    <link rel="canonical" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href={`${base}logo.svg`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}logo-cercle.png`} />
    <link rel="apple-touch-icon" href={`${base}logo-cercle.png`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${business.name} — Magnétiseuse`} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta
      property="og:image:alt"
      content={`Logo ${business.name} — Magnétiseuse à Clermont-Ferrand`}
    />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card (reprend les balises og:* en repli) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:image:alt"
      content={`Logo ${business.name} — Magnétiseuse à Clermont-Ferrand`}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Google Calendar (bouton de prise de rendez-vous) -->
    <link
      href="https://calendar.google.com/calendar/scheduling-button-script.css"
      rel="stylesheet"
    />
    <script src="https://calendar.google.com/calendar/scheduling-button-script.js" async is:inline
    ></script>

    <!-- Schema.org JSON-LD (LocalBusiness du site + schémas propres à la page) -->
    <JsonLd image={ogImageUrl} schema={jsonLd} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Aller au contenu</a>

    <Nav minimal={minimalNav} />
    {!minimalNav && <MobileMenu />}

    <main id="main-content">
      <slot />
    </main>

    {!noFooter && <Footer />}

    <CookieBanner />

    {!minimalNav && <FloatingCalendarButton />}

    <script>
      // Apparition au défilement : ajoute la classe `.visible` aux éléments
      // `.reveal` dès qu'ils entrent dans le viewport (l'animation est en CSS).
      // Comportement transversal (éléments présents dans plusieurs composants),
      // d'où sa place dans le layout. Les comportements propres à un composant
      // vivent dans le <script> du composant correspondant.
      const reveals = document.querySelectorAll('.reveal');

      if (reveals.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1 },
        );

        reveals.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
